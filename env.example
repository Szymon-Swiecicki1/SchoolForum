// Tracking variables for class/subject navigation on files tab
let selectedClass: string | null = null;
let selectedSubject: string | null = null;

export function GetExamFiles(): ExamFile[] {
  const data = localStorage.getItem("sf_files");
  if (!data) {
    localStorage.setItem("sf_files", JSON.stringify(INITIAL_FILES));
    return INITIAL_FILES;
  }
  try {
    return JSON.parse(data);
  } catch (_) {
    return INITIAL_FILES;
  }
}

export function SaveExamFiles(files: ExamFile[]): void {
  localStorage.setItem("sf_files", JSON.stringify(files));
}

export function AddExamFile(
  classId: string,
  subjectId: string,
  name: string,
  description: string,
  fileName: string,
  fileSize: string
): ExamFile {
  const currentUser = GetCurrentUser();
  const list = GetExamFiles();

  const newFile: ExamFile = {
    id: "file_" + Date.now(),
    classId,
    subjectId,
    name,
    description,
    fileName,
    fileSize,
    uploadedBy: currentUser.fullname,
    date: new Date().toISOString().replace("T", " ").substring(0, 16),
    downloadsCount: 0
  };

  list.unshift(newFile);
  SaveExamFiles(list);
  return newFile;
}

export function IncrementDownloads(fileId: string): void {
  const list = GetExamFiles();
  const fileIndex = list.findIndex(f => f.id === fileId);
  if (fileIndex !== -1) {
    list[fileIndex].downloadsCount += 1;
    SaveExamFiles(list);
  }
}

/**
 * Render general sheets and exams tab.
 */
export function RenderFilesModule(): void {
  const tabs = document.querySelectorAll(".file-class-tab");
  tabs.forEach(tab => {
    const tabClass = tab.getAttribute("data-class");
    if (tabClass === selectedClass) {
      tab.classList.remove("text-slate-650", "dark:text-slate-400", "bg-transparent");
      tab.classList.add("bg-white", "dark:bg-slate-950", "text-blue-600", "dark:text-[#ffffff]", "shadow-xs");
    } else {
      tab.classList.add("text-slate-650", "dark:text-slate-400", "bg-transparent");
      tab.classList.remove("bg-white", "dark:bg-slate-950", "text-blue-600", "dark:text-[#ffffff]", "shadow-xs");
    }
  });

  const grid = document.getElementById("files_subjects_grid");
  const subjectsSection = document.getElementById("files_subjects_section");
  const container = document.getElementById("files_list_container");

  if (!selectedClass) {
    if (subjectsSection) subjectsSection.classList.add("hidden");
    if (container) container.classList.add("hidden");
    if (grid) grid.innerHTML = "";
    return;
  }

  if (subjectsSection) subjectsSection.classList.remove("hidden");

  if (grid) {
    const SUBJECT_LIST = [
      "Polski",
      "Matematyka",
      "Angielski",
      "Historia",
      "Fizyka",
      "Chemia",
      "Biologia",
      "Geografia",
      "Informatyka",
      "WOS"
    ];

    grid.innerHTML = SUBJECT_LIST.map(sub => {
      const isSelected = sub === selectedSubject;
      const themeColors = isSelected 
        ? "bg-blue-600 text-white border-blue-600 scale-[1.03]" 
        : "bg-white dark:bg-[#0c1424] text-slate-800 dark:text-slate-300 border-slate-205 dark:border-slate-850 hover:border-blue-500 hover:text-blue-600";
      
      return `
        <button class="file-subject-btn px-4 py-3 rounded-2xl text-xs font-bold border transition-all cursor-pointer shadow-2xs text-center ${themeColors}" data-subject="${sub}">
          ${sub}
        </button>
      `;
    }).join("");

    document.querySelectorAll(".file-subject-btn").forEach(btn => {
      btn.addEventListener("click", (e) => {
        const sub = (e.currentTarget as HTMLElement).getAttribute("data-subject");
        selectedSubject = sub;
        RenderFilesModule();
      });
    });
  }

  if (!selectedSubject) {
    if (container) container.classList.add("hidden");
    return;
  }

  if (container) {
    container.classList.remove("hidden");

    const allFiles = GetExamFiles();
    const filteredFiles = allFiles.filter(f => f.classId === selectedClass && f.subjectId === selectedSubject);

    let filesFeedHtml = "";
    if (filteredFiles.length === 0) {
      filesFeedHtml = `
        <div class="py-10 text-center rounded-2xl bg-slate-50 dark:bg-slate-900/40 border border-slate-150 dark:border-slate-850">
          <p class="text-xs text-slate-500">Brak załączonych arkuszy dla tego przedmiotu i klasy. Kliknij "Dodaj plik" na górze, by dołożyć własną pomoc naukową!</p>
        </div>
      `;
    } else {
      filesFeedHtml = filteredFiles.map(f => {
        const isDocx = f.fileName.endsWith(".docx");
        const badgeColor = isDocx 
          ? "bg-blue-100 text-blue-650 dark:bg-blue-950/40 dark:text-blue-450" 
          : "bg-red-105 text-red-650 dark:bg-red-950/40 dark:text-red-400";
        const fileExtLabel = isDocx ? "DOCX WORD" : "DOKUMENT PDF";

        return `
          <!-- File Row Card -->
          <div class="p-4 rounded-2xl border border-slate-200 dark:border-slate-850 bg-slate-50/20 dark:bg-slate-950/20 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div class="flex items-start gap-3.5 min-w-0">
              <!-- Document Icon representation -->
              <div class="w-11 h-11 shrink-0 flex flex-col items-center justify-center rounded-xl p-1 font-extrabold text-[8px] tracking-tighter ${badgeColor} border border-slate-200 dark:border-slate-800">
                <svg class="w-5 h-5 mb-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                ${isDocx ? 'DOCX' : 'PDF'}
              </div>
              <div class="space-y-1 min-w-0">
                <h4 class="font-bold text-xs sm:text-sm text-slate-900 dark:text-white leading-snug truncate" title="${f.name}">${f.name}</h4>
                <p class="text-xs text-slate-500 dark:text-slate-400 leading-normal line-clamp-2">${f.description}</p>
                <div class="flex flex-wrap items-center gap-2 text-[10px] font-bold text-slate-400 dark:text-slate-500 select-none">
                  <span>Nazwa: <span class="text-slate-600 dark:text-slate-350 font-medium">${f.fileName}</span></span>
                  <span>&bull;</span>
                  <span>Rozmiar: <span class="text-slate-600 dark:text-slate-350 font-medium">${f.fileSize}</span></span>
                  <span>&bull;</span>
                  <span>Wgrał: <span class="text-blue-500 font-medium">${f.uploadedBy}</span></span>
                  <span>&bull;</span>
                  <span>Pobrań: <span class="text-slate-600 dark:text-slate-300 font-bold">${f.downloadsCount}</span></span>
                </div>
              </div>
            </div>

            <!-- Download and Delete Controls Row -->
            <div class="flex items-center gap-2 w-full sm:w-auto mt-2 sm:mt-0 shrink-0">
              <button class="download-live-file-btn flex-grow px-4.5 py-2.5 rounded-xl bg-indigo-600 hover:bg-indigo-750 text-white font-bold text-xs shadow-sm transition-all text-center cursor-pointer" data-file-id="${f.id}" data-filename="${f.fileName}">
                Rozpocznij Pobieranie
              </button>
              ${(() => {
                const currentUser = GetCurrentUser();
                const isAdminUser = IsAdmin();
                const isUploadedByCurrentUser = f.uploadedBy === currentUser.fullname || f.uploadedBy === currentUser.email;
                if (isUploadedByCurrentUser || isAdminUser) {
                  return `
                    <button class="delete-file-btn p-2.5 rounded-xl border border-rose-200 dark:border-rose-950/40 text-rose-500 hover:bg-rose-50 dark:hover:bg-rose-950/20 cursor-pointer text-xs" data-file-id="${f.id}" title="Usuń plik">
                      🗑️
                    </button>
                  `;
                }
                return "";
              })()}
            </div>
          </div>
        `;
      }).join("");
    }

    container.innerHTML = `
      <div class="flex items-center justify-between pb-3 border-b border-slate-100 dark:border-slate-850">
        <div>
          <span class="text-xs font-bold text-slate-400 uppercase tracking-wide">Repozytorium Arkuszy:</span>
          <h2 class="text-md sm:text-lg font-extrabold text-[#3848df] dark:text-[#6e7bff] leading-tight">${selectedClass} &middot; ${selectedSubject}</h2>
        </div>
        <button id="close_files_view_btn" class="text-xs font-bold text-slate-405 hover:text-slate-850 dark:hover:text-white hover:underline cursor-pointer">Zmień kategorię</button>
      </div>

      <div class="space-y-3.5 pt-2">
        ${filesFeedHtml}
      </div>
    `;

    // Bind event keys inside sub-component
    const closeFilesBtn = document.getElementById("close_files_view_btn");
    if (closeFilesBtn) {
      closeFilesBtn.addEventListener("click", () => {
        selectedSubject = null;
        RenderFilesModule();
      });
    }

    // Bind Downloads triggers
    document.querySelectorAll(".download-live-file-btn").forEach(btn => {
      btn.addEventListener("click", (e) => {
        const fileId = (e.currentTarget as HTMLElement).getAttribute("data-file-id");
        const filename = (e.currentTarget as HTMLElement).getAttribute("data-filename");
        if (fileId && filename) {
          IncrementDownloads(fileId);
          alert(`Inicjalizacja pobierania załącznika szkolnego: ${filename}\nStatystyki licznika pobrań zwiększyły się!`);
          RenderFilesModule();
        }
      });
    });

    // Bind File deletions
    document.querySelectorAll(".delete-file-btn").forEach(btn => {
      btn.addEventListener("click", (e) => {
        const fileId = (e.currentTarget as HTMLElement).getAttribute("data-file-id");
        if (fileId) {
          customConfirm("USUWANIE ARKUSZA", "Czy na pewno chcesz bezpowrotnie usunąć ten plik/arkusz z bazy?", () => {
            const list = GetExamFiles();
            const filtered = list.filter(f => f.id !== fileId);
            SaveExamFiles(filtered);
            RenderFilesModule();
          });
        }
      });
    });
  }
}

/**
 * Handle triggering of "Dodaj plik" modal in App
 */
export function InitFilesController(): void {
  // Select user default class from their preferences dynamically
  const user = GetCurrentUser();
  selectedClass = user.schoolClass || "2LO";
  selectedSubject = "Matematyka";

  const tabs = document.querySelectorAll(".file-class-tab");
  tabs.forEach(tab => {
    tab.addEventListener("click", (e) => {
      const classId = (e.currentTarget as HTMLElement).getAttribute("data-class");
      selectedClass = classId;
      selectedSubject = null; // Reset select subject to prompt choix
      RenderFilesModule();
    });
  });

  RenderFilesModule();
}
