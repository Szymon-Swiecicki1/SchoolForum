<!DOCTYPE html>
<html lang="pl" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SchoolForum - Platforma Uczniowska</title>
    <link rel="stylesheet" href="css/style.css">
    <script>
        // Critical block path to set theme before rendering content
        try {
            const cachedTheme = localStorage.getItem('theme') || 'dark';
            if (cachedTheme === 'light') {
                document.documentElement.classList.remove('dark');
            } else {
                document.documentElement.classList.add('dark');
            }
        } catch (_) {}
    </script>
</head>
<body class="min-h-screen transition-colors duration-200 font-sans selection:bg-blue-600 selection:text-white dark:bg-[#070d19] bg-[#f8fafc] text-slate-800 dark:text-slate-150 pb-20 md:pb-0">

    <!-- App Shell Wrapper (Flex Container) -->
    <div class="flex max-w-7xl mx-auto min-h-screen relative">

        <!-- 1. LEFT SIDEBAR (X-Style, visible on desktop) -->
        <aside class="hidden md:flex flex-col justify-between w-64 h-screen sticky top-0 border-r border-slate-205 dark:border-slate-850 p-6 bg-white dark:bg-[#0c1424] z-40">
            <!-- Top Section -->
            <div class="space-y-8">
                <!-- Mascot/Logo header -->
                <div class="flex items-center gap-3 pl-2">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-blue-600 to-indigo-750 text-white flex items-center justify-center shadow shadow-blue-500/30">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                        </svg>
                    </div>
                    <div>
                        <div class="font-extrabold text-base text-slate-900 dark:text-white leading-tight">SchoolForum</div>
                        <div class="text-[10px] text-slate-450 dark:text-slate-500 font-bold uppercase tracking-wider">Dla Licealistów</div>
                    </div>
                </div>

                <!-- Navigation List -->
                <nav class="space-y-1">
                    <!-- Tab 1: Forum -->
                    <button class="tab-btn w-full flex items-center gap-4 px-4 py-3 rounded-2xl text-base font-semibold text-slate-650 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-850 hover:text-blue-600 dark:hover:text-blue-400 transition-all cursor-pointer" data-tab="forum">
                        <i data-lucide="message-square" class="w-5 h-5"></i>
                        <span>Forum</span>
                    </button>

                    <!-- Tab 2: Pytania (Sprawdziany) -->
                    <button class="tab-btn w-full flex items-center gap-4 px-4 py-3 rounded-2xl text-base font-semibold text-slate-650 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-850 hover:text-blue-600 dark:hover:text-blue-400 transition-all cursor-pointer" data-tab="exams">
                        <i data-lucide="help-circle" class="w-5 h-5"></i>
                        <span>Pytania</span>
                    </button>

                    <!-- Tab 3: Przykładowe Egzaminy -->
                    <button class="tab-btn w-full flex items-center gap-4 px-4 py-3 rounded-2xl text-base font-semibold text-slate-650 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-850 hover:text-blue-600 dark:hover:text-blue-400 transition-all cursor-pointer" data-tab="files">
                        <i data-lucide="book-open" class="w-5 h-5"></i>
                        <span>Arkusze</span>
                    </button>

                    <!-- Tab 4: Moje Konto -->
                    <button class="tab-btn w-full flex items-center gap-4 px-4 py-3 rounded-2xl text-base font-semibold text-slate-650 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-850 hover:text-blue-600 dark:hover:text-blue-400 transition-all cursor-pointer" data-tab="account">
                        <i data-lucide="user" class="w-5 h-5"></i>
                        <span>Konto</span>
                    </button>

                    <!-- Tab 6: Panel Admin -->
                    <button id="admin_sidebar_btn" class="tab-btn w-full hidden flex items-center gap-4 px-4 py-3 rounded-2xl text-base font-semibold text-slate-650 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-850 hover:text-rose-600 dark:hover:text-rose-400 transition-all cursor-pointer" data-tab="admin">
                        <i data-lucide="shield" class="w-5 h-5 text-rose-500"></i>
                        <span class="text-rose-600 dark:text-rose-405 font-extrabold">Panel Admin</span>
                    </button>

                    <!-- Tab 5: Ustawienia -->
                    <button class="tab-btn w-full flex items-center gap-4 px-4 py-3 rounded-2xl text-base font-semibold text-slate-650 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-850 hover:text-blue-600 dark:hover:text-blue-400 transition-all cursor-pointer" data-tab="settings">
                        <i data-lucide="settings" class="w-5 h-5"></i>
                        <span>Ustawienia</span>
                    </button>
                </nav>
            </div>

            <!-- Bottom User Section -->
            <div class="border-t border-slate-100 dark:border-slate-850 pt-5 space-y-4">
                <div class="flex items-center justify-between gap-2.5">
                    <div class="flex items-center gap-3 overflow-hidden">
                        <img id="sidebar_avatar" src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=256&auto=format&fit=crop" alt="Avatar" class="w-10 h-10 rounded-full border border-slate-200 dark:border-slate-700 object-cover shrink-0" />
                        <div class="overflow-hidden">
                            <div id="sidebar_fullname" class="font-extrabold text-xs text-slate-800 dark:text-slate-200 truncate leading-tight">Uczeń Szkoły</div>
                            <div id="sidebar_email" class="text-[9px] text-slate-550 dark:text-slate-400 truncate">uczen@szkola.edu.pl</div>
                        </div>
                    </div>
                    <!-- Quick Sun/Moon Global Theme toggler for desktop -->
                    <button id="global_theme_toggle_btn" class="p-2 rounded-xl text-slate-400 hover:text-blue-500 hover:bg-slate-50 dark:hover:bg-slate-900 cursor-pointer transition-all" title="Zmień motyw">
                        <span class="hidden dark:inline-block"><i data-lucide="sun" class="w-4.5 h-4.5"></i></span>
                        <span class="inline-block dark:hidden"><i data-lucide="moon" class="w-4.5 h-4.5"></i></span>
                    </button>
                </div>
                <button id="logout_btn" class="w-full flex items-center justify-center gap-2 px-3 py-2.5 rounded-xl border border-red-200 dark:border-red-950/60 text-xs font-semibold text-red-650 dark:text-red-400 bg-red-50/20 dark:bg-red-950/10 hover:bg-red-50 dark:hover:bg-red-950/25 transition-all cursor-pointer">
                    <i data-lucide="log-out" class="w-3.5 h-3.5"></i>
                    <span>Wyloguj się</span>
                </button>
            </div>
        </aside>

        <!-- 2. MOBILE BOTTOM NAVIGATION (visible on mobile only) -->
        <nav class="md:hidden fixed bottom-0 left-0 right-0 h-16 bg-white dark:bg-[#0c1424] border-t border-slate-200 dark:border-slate-850 flex justify-around items-center z-40 shadow-lg px-2">
            <!-- Tab: Forum -->
            <button class="tab-btn flex flex-col items-center justify-center gap-1.5 py-1 px-3 rounded-xl text-slate-450 hover:text-blue-500" data-tab="forum">
                <i data-lucide="message-square" class="w-5 h-5"></i>
                <span class="text-[9px] font-bold">Forum</span>
            </button>
            <!-- Tab: Exams (Pytania) -->
            <button class="tab-btn flex flex-col items-center justify-center gap-1.5 py-1 px-3 rounded-xl text-slate-450 hover:text-blue-500" data-tab="exams">
                <i data-lucide="help-circle" class="w-5 h-5"></i>
                <span class="text-[9px] font-bold">Pytania</span>
            </button>
            <!-- Tab: Files (Arkusze) -->
            <button class="tab-btn flex flex-col items-center justify-center gap-1.5 py-1 px-3 rounded-xl text-slate-450 hover:text-blue-500" data-tab="files">
                <i data-lucide="book-open" class="w-5 h-5"></i>
                <span class="text-[9px] font-bold">Arkusze</span>
            </button>
            <!-- Tab: Account -->
            <button class="tab-btn flex flex-col items-center justify-center gap-1.5 py-1 px-3 rounded-xl text-slate-450 hover:text-blue-500" data-tab="account">
                <i data-lucide="user" class="w-5 h-5"></i>
                <span class="text-[9px] font-bold">Profil</span>
            </button>
            <!-- Tab: Admin Panel -->
            <button id="mobile_admin_sidebar_btn" class="tab-btn hidden flex flex-col items-center justify-center gap-1.5 py-1 px-3 rounded-xl text-slate-450 hover:text-rose-500" data-tab="admin">
                <i data-lucide="shield" class="w-5 h-5 text-rose-500"></i>
                <span class="text-[9px] font-extrabold text-rose-600 dark:text-rose-400">Admin</span>
            </button>
            <!-- Tab: Settings -->
            <button class="tab-btn flex flex-col items-center justify-center gap-1.5 py-1 px-3 rounded-xl text-slate-450 hover:text-blue-500" data-tab="settings">
                <i data-lucide="settings" class="w-5 h-5"></i>
                <span class="text-[9px] font-bold">Ucz</span>
            </button>
        </nav>

        <!-- 3. CENTRAL MAIN VIEWS AREA (Acts as viewport) -->
        <div class="flex-grow min-h-screen px-4 py-6 sm:p-8 lg:p-10 w-full overflow-y-auto max-w-4xl">
            <!-- Mobile Header with theme switcher and logout -->
            <header class="md:hidden flex items-center justify-between mb-6 pb-4 border-b border-slate-100 dark:border-slate-855">
                <div class="flex items-center gap-2">
                    <img id="mobile_avatar" src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=256&auto=format&fit=crop" alt="Avatar" class="w-8 h-8 rounded-full border border-slate-200 dark:border-slate-700 object-cover shrink-0" />
                    <span class="font-extrabold text-slate-900 dark:text-white text-md">SchoolForum</span>
                </div>
                <div class="flex items-center gap-2">
                    <!-- Global theme switcher for mobile layout -->
                    <button id="mobile_theme_toggle_btn" class="p-2 rounded-xl text-slate-450 hover:text-blue-500 hover:bg-slate-50 dark:hover:bg-slate-900 cursor-pointer transition-all">
                        <span class="hidden dark:inline-block"><i data-lucide="sun" class="w-4 h-4"></i></span>
                        <span class="inline-block dark:hidden"><i data-lucide="moon" class="w-4 h-4"></i></span>
                    </button>
                    <button id="mobile_logout_btn" class="p-1 px-2.5 rounded-lg border border-red-200 dark:border-red-950 text-red-550 dark:text-red-400 text-xs font-semibold bg-red-50/20 dark:bg-red-950/10 hover:bg-red-100 dark:hover:bg-red-900/20 transition-all cursor-pointer">
                        Wyjdź
                    </button>
                </div>
            </header>

            <!-- ================= ZAKŁADKA 1: FORUM ================= -->
            <section id="view_forum" class="tab-view space-y-6">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                    <div>
                        <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Forum Społecznościowe</h1>
                        <p class="text-sm text-slate-500 dark:text-slate-450">Wyraź opinię, zadaj pytanie lub pomóż innym w nauce</p>
                    </div>
                    <!-- Add Post Trigger -->
                    <button id="add_post_btn" class="cursor-pointer inline-flex items-center gap-2 px-5 py-2.5 rounded-2xl bg-blue-600 hover:bg-blue-700 font-semibold text-sm text-white shadow-lg shadow-blue-500/10 transition-all hover:scale-[1.02] active:scale-[0.98]">
                        <span class="text-lg leading-none">+</span> Dodaj nowy post
                    </button>
                </div>

                <!-- Filters panel -->
                <div class="p-4 rounded-2xl bg-white dark:bg-[#0c1424] border border-slate-150 dark:border-slate-850/60 shadow-sm flex flex-col sm:flex-row items-center gap-4">
                    <span class="text-xs font-extrabold uppercase tracking-widest text-[#245ce6] dark:text-[#5283ff] shrink-0">Filtrowanie:</span>
                    
                    <div class="w-full sm:w-auto flex flex-wrap gap-3 flex-grow">
                        <!-- Class Select Filter -->
                        <div class="relative flex-grow sm:flex-grow-0 sm:w-40">
                            <select id="filter_class" class="w-full pl-3 pr-8 py-2 text-xs rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-250 dark:border-slate-800 text-slate-800 dark:text-slate-250 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-all cursor-pointer appearance-none">
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="all">Wszystkie klasy</option>
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="1LO">1LO</option>
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="2LO">2LO</option>
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="3LO">3LO</option>
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="4LO">4LO</option>
                            </select>
                            <span class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400 text-[10px]">&darr;</span>
                        </div>

                        <!-- Subject Select Filter -->
                        <div class="relative flex-grow sm:flex-grow-0 sm:w-48">
                            <select id="filter_subject" class="w-full pl-3 pr-8 py-2 text-xs rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-250 dark:border-slate-800 text-slate-800 dark:text-slate-250 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-all cursor-pointer appearance-none">
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="all">Wszystkie przedmioty</option>
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="Polski">Polski</option>
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="Matematyka">Matematyka</option>
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="Angielski">Angielski</option>
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="Historia">Historia</option>
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="Fizyka">Fizyka</option>
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="Chemia">Chemia</option>
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="Biologia">Biologia</option>
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="Geografia">Geografia</option>
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="Informatyka">Informatyka</option>
                                <option class="bg-white text-slate-900 dark:bg-[#0c1424] dark:text-zinc-100" value="WOS">WOS</option>
                            </select>
                            <span class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400 text-[10px]">&darr;</span>
                        </div>
                    </div>

                    <!-- Clear Filters -->
                    <button id="clear_filters_btn" class="w-full sm:w-auto px-4 py-2 text-xs font-semibold text-slate-500 dark:text-slate-400 hover:text-blue-500 dark:hover:text-blue-400 transition-colors bg-slate-100/40 dark:bg-slate-900/40 hover:bg-slate-100 dark:hover:bg-slate-850 rounded-xl cursor-pointer">
                        Wyczyść
                    </button>
                </div>

                <!-- Feed/Posts container -->
                <div id="forum_posts_feed" class="space-y-4">
                    <!-- Loaded dynamically via forum.ts -->
                </div>
            </section>

            <!-- ================= ZAKŁADKA 2: PYTANIA (EGZAMINY I PYTANIA) ================= -->
            <section id="view_exams" class="tab-view space-y-6 hidden">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Pytania</h1>
                    <p class="text-sm text-slate-500 dark:text-slate-405">Przeglądaj zadania szkolne pogrupowane według klas i przedmiotów</p>
                </div>

                <!-- Class tabs container with dynamic integrated hover menus inside exams.ts -->
                <div id="exams_class_tabs_container" class="grid grid-cols-5 gap-2 bg-slate-100/80 dark:bg-slate-900/60 p-1.5 rounded-2xl border border-slate-200 dark:border-slate-850 relative">
                     <!-- Populated with hover belts dynamically via exams.ts! -->
                </div>

                <!-- Mini Forum Area (initially instruction or list) -->
                <div id="exams_chat_container" class="hidden p-5 rounded-3xl bg-white dark:bg-[#0c1424] border border-slate-200 dark:border-slate-850 shadow-sm space-y-4">
                    <!-- Dynamic view with Title, post question input and current lists of questions -->
                </div>
            </section>

            <!-- ================= ZAKŁADKA 3: PRZYKŁADOWE EGZAMINY ================= -->
            <section id="view_files" class="tab-view space-y-6 hidden">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                    <div>
                        <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Przykładowe Egzaminy</h1>
                        <p class="text-sm text-slate-500 dark:text-slate-450">Pobieraj i dodawaj oficjalne arkusze maturalne i sprawdziany (PDF/DOCX)</p>
                    </div>
                    <!-- Add File Trigger inside selected category -->
                    <button id="add_file_trigger_btn" class="cursor-pointer inline-flex items-center gap-2 px-5 py-2.5 rounded-2xl bg-indigo-600 hover:bg-indigo-750 font-semibold text-sm text-white shadow-lg transition-all hover:scale-[1.02] active:scale-[0.98]">
                        <span class="text-sm">+</span> Dodaj plik
                    </button>
                </div>

                <!-- Class tabs -->
                <div class="grid grid-cols-4 gap-2 bg-slate-100/80 dark:bg-slate-900/60 p-1.5 rounded-2xl border border-slate-200 dark:border-slate-850">
                    <button class="file-class-tab py-2.5 rounded-xl text-xs sm:text-sm font-bold text-slate-600 dark:text-slate-400 hover:text-slate-800 dark:hover:text-[#ffffff] bg-transparent transition-all cursor-pointer" data-class="1LO">1LO</button>
                    <button class="file-class-tab py-2.5 rounded-xl text-xs sm:text-sm font-bold text-slate-600 dark:text-slate-400 hover:text-slate-800 dark:hover:text-[#ffffff] bg-transparent transition-all cursor-pointer" data-class="2LO">2LO</button>
                    <button class="file-class-tab py-2.5 rounded-xl text-xs sm:text-sm font-bold text-slate-600 dark:text-slate-400 hover:text-slate-800 dark:hover:text-[#ffffff] bg-transparent transition-all cursor-pointer" data-class="3LO">3LO</button>
                    <button class="file-class-tab py-2.5 rounded-xl text-xs sm:text-sm font-bold text-slate-600 dark:text-slate-400 hover:text-slate-800 dark:hover:text-[#ffffff] bg-transparent transition-all cursor-pointer" data-class="4LO">4LO</button>
                </div>

                <!-- Subjects list (visible after choosing class) -->
                <div id="files_subjects_section" class="space-y-4">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Wybierz przedmiot:</p>
                    <div class="grid grid-cols-2 sm:grid-cols-5 gap-3" id="files_subjects_grid">
                        <!-- Instantiated via files.ts -->
                    </div>
                </div>

                <!-- File List Area -->
                <div id="files_list_container" class="hidden p-5 rounded-3xl bg-white dark:bg-[#0c1424] border border-slate-200 dark:border-slate-855 shadow-sm space-y-4">
                    <!-- Loaded dynamically via files.ts -->
                </div>
            </section>

            <!-- ================= ZAKŁADKA 4: MOJE KONTO ================= -->
            <section id="view_account" class="tab-view space-y-6 hidden">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Konto Użytkownika</h1>
                    <p class="text-sm text-slate-500 dark:text-slate-405">Zarządzaj swoim publicznym profilem szkolnym i przeglądaj aktywności</p>
                </div>

                <!-- User profile editor card -->
                <div class="p-6 sm:p-8 rounded-3xl bg-white dark:bg-[#0c1424] border border-slate-150 dark:border-slate-850/70 shadow-sm space-y-6">
                    <div class="flex flex-col sm:flex-row items-center gap-6 pb-6 border-b border-slate-100 dark:border-slate-850">
                        <!-- Avatar uploader -->
                        <div class="relative group cursor-pointer w-24 h-24 shrink-0">
                            <img id="profile_photo_preview" src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=256&auto=format&fit=crop" alt="Profilowe" class="w-full h-full rounded-2xl border-2 border-slate-205 dark:border-slate-700 object-cover shadow-inner" />
                            <div class="absolute inset-0 bg-black/60 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center text-white text-[10px] font-bold pointer-events-none">
                                <svg class="w-5 h-5 mb-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                ZMIEŃ ZDJĘCIE
                            </div>
                            <input type="file" id="profile_image_input" class="hidden" accept="image/*" />
                        </div>

                        <!-- Main information -->
                        <div class="space-y-4 flex-grow w-full">
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <!-- Imię i nazwisko -->
                                <div>
                                    <label for="profile_fullname" class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-1">Imię i Nazwisko</label>
                                    <input type="text" id="profile_fullname" placeholder="np. Jan Kowalski" class="w-full px-4 py-2 text-sm rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-850 dark:text-white placeholder-slate-450 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-all" value="Zofia Wiśniewska" />
                                </div>
                                <!-- Klasa z listy rozwijanej -->
                                <div>
                                    <label for="profile_class" class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-1">Klasa</label>
