            <!-- User Activity lists -->
            <div class="space-y-2.5 max-h-56 overflow-y-auto">
                <span class="block text-xs font-semibold text-slate-400 uppercase tracking-widest">Aktywność na forum:</span>
                <div id="profile_modal_activity_feed" class="space-y-2">
                    <!-- Loaded dynamically -->
                </div>
            </div>

            <div class="flex justify-end pt-2 border-t border-slate-100 dark:border-slate-850">
                <button type="button" id="close_profile_modal_btn_alt" class="cursor-pointer px-5 py-2 rounded-xl bg-slate-100 dark:bg-slate-900 text-slate-700 dark:text-slate-350 hover:bg-slate-205 text-xs font-bold transition-colors">Zamknij profil</button>
            </div>
        </div>
    </div>

    <!-- ================= ADD POST MODAL PANEL ================= -->
    <div id="add_post_modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/75 backdrop-blur-xs p-4 overflow-y-auto">
        <div class="w-full max-w-lg bg-white dark:bg-[#0c1424] border border-slate-200 dark:border-slate-850 rounded-3xl overflow-hidden p-6 sm:p-8 space-y-5 animate-in fade-in duration-100">
            <div class="flex items-center justify-between border-b border-slate-100 dark:border-slate-850 pb-4">
                <h3 class="font-extrabold text-slate-900 dark:text-white text-lg">Stwórz nowy post</h3>
                <button type="button" class="close-modal-btn font-extrabold text-slate-400 dark:text-slate-550 hover:text-slate-200 text-lg cursor-pointer">✕</button>
            </div>

            <!-- Form Body -->
            <form id="add_post_form" class="space-y-4">
                <!-- Tytuł -->
                <div class="space-y-1">
                    <label for="post_form_title" class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Tytuł posta</label>
                    <input type="text" id="post_form_title" placeholder="np. Zadanie z funkcji kwadratowej - pomoc!" class="w-full px-4 py-2.5 rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" required />
                </div>

                <!-- Klasa i Przedmiot -->
                <div class="grid grid-cols-2 gap-3">
                    <div class="space-y-1">
                        <label for="post_form_class" class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Klasa docelowa</label>
                        <select id="post_form_class" class="w-full px-3 py-2 text-xs rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-850 dark:text-white cursor-pointer focus:ring-1 focus:ring-blue-500">
                            <option value="1LO">1LO</option>
                            <option value="2LO" selected>2LO</option>
                            <option value="3LO">3LO</option>
                            <option value="4LO">4LO</option>
                        </select>
                    </div>
                    <div class="space-y-1">
                        <label for="post_form_subject" class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Przedmiot</label>
                        <select id="post_form_subject" class="w-full px-3 py-2 text-xs rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-850 dark:text-white cursor-pointer focus:ring-1 focus:ring-blue-500">
                            <option value="Polski">Polski</option>
                            <option value="Matematyka" selected>Matematyka</option>
                            <option value="Angielski">Angielski</option>
                            <option value="Historia">Historia</option>
                            <option value="Fizyka">Fizyka</option>
                            <option value="Chemia">Chemia</option>
                            <option value="Biologia">Biologia</option>
                            <option value="Geografia">Geografia</option>
                            <option value="Informatyka">Informatyka</option>
                            <option value="WOS">WOS</option>
                        </select>
                    </div>
                </div>

                <!-- Treść -->
                <div class="space-y-1">
                    <label for="post_form_content" class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Treść wpisu</label>
                    <textarea id="post_form_content" rows="4" placeholder="Wpisz swoje pytanie lub notatkę..." class="w-full px-4 py-2.5 rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" required></textarea>
                </div>

                <!-- Załącznik File Uploader -->
                <div class="space-y-1">
                    <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Załącznik (Opcjonalnie PDF/DOCX)</label>
                    <div id="post_file_dropzone" class="border border-dashed border-slate-250 dark:border-slate-800 rounded-xl p-4 flex flex-col items-center justify-center bg-slate-50 dark:bg-slate-900/40 hover:bg-slate-100 dark:hover:bg-slate-900/60 cursor-pointer transition-all">
                        <i data-lucide="book-open" class="w-6 h-6 text-slate-400 mb-1.5"></i>
                        <span class="text-xs font-semibold text-slate-650 dark:text-slate-355" id="post_file_label">Kliknij lub upuść plik tutaj</span>
                        <span class="text-[9px] text-slate-450 mt-0.5">Dozwolone formaty: PDF, DOCX (Maks. 15MB)</span>
                        <input type="file" id="post_file_input" class="hidden" accept=".pdf,.docx" />
                    </div>
                </div>

                <!-- Submit / Cancel -->
                <div class="flex items-center justify-end gap-3 pt-3 border-t border-slate-100 dark:border-slate-850">
                    <button type="button" class="close-modal-btn cursor-pointer px-4 py-2 text-xs font-bold text-slate-500 dark:text-slate-400 hover:text-slate-800 dark:hover:text-white transition-colors">Anuluj</button>
                    <button type="submit" class="cursor-pointer px-6 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-semibold text-xs shadow shadow-blue-500/10">Dodaj na forum</button>
                </div>
            </form>
        </div>
    </div>

    <!-- ================= ADD FILE MODAL PANEL ================= -->
    <div id="add_file_modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/75 backdrop-blur-xs p-4 overflow-y-auto">
        <div class="w-full max-w-lg bg-white dark:bg-[#0c1424] border border-slate-200 dark:border-slate-850 rounded-3xl overflow-hidden p-6 sm:p-8 space-y-5 animate-in fade-in duration-100">
            <div class="flex items-center justify-between border-b border-slate-100 dark:border-slate-850 pb-4">
                <h3 class="font-extrabold text-slate-900 dark:text-white text-lg">Dodaj nowy arkusz / plik</h3>
                <button type="button" class="close-file-modal-btn font-extrabold text-slate-400 dark:text-slate-550 hover:text-slate-200 text-lg cursor-pointer">✕</button>
            </div>

            <!-- Form Body -->
            <form id="add_file_form" class="space-y-4">
                <!-- Nazwa pliku -->
                <div class="space-y-1">
                    <label for="file_form_name" class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Nazwa arkusza / zakres materiału</label>
                    <input type="text" id="file_form_name" placeholder="np. Sprawdzian z hydrostatyki z odpowiedziami" class="w-full px-4 py-2.5 rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" required />
                </div>

                <!-- Klasa i Przedmiot -->
                <div class="grid grid-cols-2 gap-3">
                    <div class="space-y-1">
                        <label for="file_form_class" class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Klasa docelowa</label>
                        <select id="file_form_class" class="w-full px-3 py-2 text-xs rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-850 dark:text-white cursor-pointer focus:ring-1 focus:ring-blue-500">
                            <option value="1LO">1LO</option>
                            <option value="2LO" selected>2LO</option>
                            <option value="3LO">3LO</option>
                            <option value="4LO">4LO</option>
                        </select>
                    </div>
                    <div class="space-y-1">
                        <label for="file_form_subject" class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Przedmiot</label>
                        <select id="file_form_subject" class="w-full px-3 py-2 text-xs rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-850 dark:text-white cursor-pointer focus:ring-1 focus:ring-blue-500">
                            <option value="Polski">Polski</option>
                            <option value="Matematyka" selected>Matematyka</option>
                            <option value="Angielski">Angielski</option>
                            <option value="Historia">Historia</option>
                            <option value="Fizyka">Fizyka</option>
                            <option value="Chemia">Chemia</option>
                            <option value="Biologia">Biologia</option>
                            <option value="Geografia">Geografia</option>
                            <option value="Informatyka">Informatyka</option>
                            <option value="WOS">WOS</option>
                        </select>
                    </div>
                </div>

                <!-- Opis szczegółowy -->
                <div class="space-y-1">
                    <label for="file_form_desc" class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider font-semibold">Czego dotyczy ten plik?</label>
                    <input type="text" id="file_form_desc" placeholder="np. Zadania z kartkówki grupy A i B wraz z naniesionym kluczem oceniania" class="w-full px-4 py-2.5 rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" required />
                </div>

                <!-- Druga sekcja Dropzone -->
                <div class="space-y-1">
                    <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Załącz plik dokumentu</label>
                    <div id="document_file_dropzone" class="border border-dashed border-slate-250 dark:border-slate-800 rounded-xl p-4 flex flex-col items-center justify-center bg-slate-50 dark:bg-slate-900/40 hover:bg-slate-100 dark:hover:bg-slate-900/60 cursor-pointer transition-all">
                        <i data-lucide="book-open" class="w-6 h-6 text-slate-400 mb-1.5"></i>
                        <span class="text-xs font-semibold text-slate-650 dark:text-slate-350" id="document_file_label">Kliknij lub upuść arkusz tutaj</span>
                        <span class="text-[9px] text-slate-450 mt-0.5">Dozwolone formaty: PDF, DOCX (Maks. 15MB)</span>
                        <input type="file" id="document_file_input" class="hidden" accept=".pdf,.docx" required />
                    </div>
                </div>

                <!-- Submit / Cancel -->
                <div class="flex items-center justify-end gap-3 pt-3 border-t border-slate-100 dark:border-slate-850">
                    <button type="button" class="close-file-modal-btn cursor-pointer px-4 py-2 text-xs font-bold text-slate-500 dark:text-slate-400 hover:text-slate-800 dark:hover:text-white transition-colors">Anuluj</button>
                    <button type="submit" class="cursor-pointer px-6 py-2.5 rounded-xl bg-indigo-600 hover:bg-indigo-750 text-white font-semibold text-xs shadow">Wgraj plik</button>
                </div>
            </form>
         </div>
    </div>

    <!-- Active Router Controller Entrypoint Script -->
    <script type="module" src="ts/router.ts"></script>
</body>
</html>
