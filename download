import { SchoolUser, GetCurrentUser, SaveUser, LogOutUser, IsAdmin, GetAllRegisteredUsers, SaveAllRegisteredUsers, customConfirm } from "./auth";
import { GetForumPosts, SaveForumPosts, RenderForumFeed } from "./forum";

// Track currently active Settings panel
let activeSection: string = "appearance";

/**
 * Switch between settings sub-sections.
 */
export function SwitchSettingsSection(sectionId: string): void {
  activeSection = sectionId;

  // Toggle active styling of navigation link buttons
  const subTabs = document.querySelectorAll(".settings-sub-tab");
  subTabs.forEach(tab => {
    const dataSection = tab.getAttribute("data-section");
    if (dataSection === activeSection) {
      tab.classList.remove("text-slate-500", "dark:text-slate-500", "bg-transparent");
      tab.classList.add("bg-blue-50/70", "dark:bg-blue-950/40", "text-blue-600", "dark:text-blue-400");
    } else {
      tab.classList.remove("bg-blue-50/70", "dark:bg-blue-950/40", "text-blue-600", "dark:text-blue-400");
      tab.classList.add("text-slate-500", "dark:text-slate-500", "bg-transparent");
    }
  });

  // Show/Hide section divs
  const sections = ["appearance", "notifications", "saved", "privacy", "admin"];
  sections.forEach(s => {
    const element = document.getElementById(`settings_section_${s}`);
    if (element) {
      if (s === activeSection) {
        element.classList.remove("hidden");
      } else {
        element.classList.add("hidden");
      }
    }
  });

  // If entering "saved" tab, re-render bookmarks lists
  if (activeSection === "saved") {
    RenderSavedPosts();
  }

  // If entering "admin" tab, re-render admin users list
  if (activeSection === "admin") {
    RenderAdminUsersList();
  }
}

